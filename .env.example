# =============================================================================
# BloCharity FastAPI Backend — Environment Variables
# =============================================================================
# Copy this file to src/.env and fill in the values for your environment.
#   cp .env.example src/.env
# =============================================================================

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost/dapp_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Blockchain / RPC --------------------------------------------------------
RPC_URL=ws://localhost:8545
HTTP_RPC_URL=http://localhost:8545
CONTRACT_ADDRESS=0x_YOUR_CONTRACT_ADDRESS_HERE
CHAIN_ID=31337

# --- Owner Keys (for backend-initiated transactions) -------------------------
OWNER_ADDRESS=0x_YOUR_OWNER_ADDRESS_HERE
OWNER_PRIVATE_KEY=0x_YOUR_OWNER_PRIVATE_KEY_HERE

# --- IPFS / Pinata -----------------------------------------------------------
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=

# --- App ---------------------------------------------------------------------
DEBUG=True
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Voting ------------------------------------------------------------------
VOTE_THRESHOLD_PERCENT=50

# --- Lottery (cron) ----------------------------------------------------------
LOTTERY_INTERVAL_HOURS=24

# --- Transaction Config ------------------------------------------------------
GAS_LIMIT=500000

# --- OpenAI (Chatbot) --------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
